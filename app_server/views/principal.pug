extends layout

block content
  .container-fluid.p-0.main-shell(style="background-color: #F8F9FA; min-height: 100vh;")
    .header-naranja.p-4.text-white.main-header(style="background: #FF8C00; border-bottom-left-radius: 40px; border-bottom-right-radius: 40px;")
      .main-header-inner
        .d-flex.justify-content-between.align-items-center.mt-2.flex-wrap.gap-3
          .d-flex.align-items-center
            .bg-white.rounded-circle.me-3.d-flex.justify-content-center.align-items-center.main-avatar(style="width: 70px; height: 70px; min-width: 70px;")
              i.bi.bi-person-fill(style="font-size: 2.3rem; color: #FF8C00;")
            div
              h2.h3.fw-bold.m-0= title
              p.m-0(style="font-size: 1.15rem;")= subtitle
          .bg-white.rounded-pill.px-4.py-2.shadow-sm.main-progress-pill
            i.bi.bi-trophy-fill.me-2(style="color: #FF8C00; font-size: 1.2rem;")
            span.fw-bold.text-dark(style="font-size: 1.15rem;")= progeso

    .cuerpo-app.px-3.mt-4.main-content
      .main-content-inner
        if success
          .alert.alert-success.shadow-sm= success
        if error
          .alert.alert-danger.shadow-sm= error

        .search-container.mb-4
          .input-group.shadow-sm(style="border-radius: 18px; overflow: hidden; border: 2px solid #FF8C00;")
            span.input-group-text.bg-white.border-0(style="padding: 0 16px;")
              i.bi.bi-search(style="color: #FF8C00; font-size: 1.4rem;")
            input.form-control.border-0.py-3(
              type="text",
              placeholder="¿Qué quieres aprender hoy?",
              style="box-shadow: none; font-size: 1.15rem;"
            )

        .card.border-0.shadow-sm.p-4.mb-4(style="border-radius: 20px; border-left: 8px solid #D35400 !important;")
          h3.fw-bold.mb-2(style="color: #D35400; font-size: 1.5rem;")= seccionTitulo
          p.text-muted.m-0(style="font-size: 1.1rem; line-height: 1.6;")= seccionDesc

        .row.g-3.m-0.modules-grid
          each modulo in modulos
            .col-12.col-lg-6.p-0.mb-3
              - const href = modulo.slug ? `/${modulo.slug}?nombre=${encodeURIComponent(userNombre || 'Usuario')}&userid=${encodeURIComponent(userid || '')}` : '#'
              a.text-decoration-none(href=href)
                .card.border-0.shadow-sm.module-card(style="border-radius: 20px;")
                  .p-3.d-flex.align-items-center.module-card-body
                    .rounded-4.d-flex.justify-content-center.align-items-center.me-3.module-icon(
                      style=`width: 82px; height: 82px; background-color: ${modulo.color}; min-width: 82px;`
                    )
                      i.bi(class=modulo.icono, style="font-size: 2.3rem; color: white;")
                    .text-start
                      h4.fw-bold.mb-2.text-dark(style="font-size: 1.4rem;")= modulo.nombre
                      p.text-muted.m-0(style="font-size: 1.08rem; line-height: 1.5;")= modulo.desc

          if cursosCreados && cursosCreados.length
            each curso in cursosCreados
              .col-12.col-lg-6.p-0.mb-3
                - const hrefCurso = curso.href || `/${curso.slug}?nombre=${encodeURIComponent(userNombre || 'Usuario')}&userid=${encodeURIComponent(userid || '')}`
                .card.border-0.shadow-sm.module-card(style="border-radius: 20px; position: relative; overflow: hidden;")

                  .position-absolute.top-0.end-0.p-2.d-flex.gap-2(style="z-index: 5;")
                    a.btn.btn-sm.btn-light.shadow-sm(
                      href=`/cursos/${curso.cursoId}/editar?nombre=${encodeURIComponent(userNombre || 'Usuario')}&userid=${encodeURIComponent(userid || '')}`,
                      title="Editar curso",
                      style="border-radius: 12px;"
                    )
                      i.bi.bi-pencil-fill(style="color:#FF8C00;")

                    button.btn.btn-sm.btn-light.shadow-sm(
                      type="button",
                      title="Eliminar curso",
                      style="border-radius: 12px;",
                      onclick=`eliminarCursoCreado('${curso.cursoId}', '${encodeURIComponent(userNombre || 'Usuario')}', '${encodeURIComponent(userid || '')}')`
                    )
                      i.bi.bi-trash-fill.text-danger

                  a.text-decoration-none(href=hrefCurso)
                    .p-3.d-flex.align-items-center.module-card-body(style="padding-right: 92px !important;")
                      .rounded-4.d-flex.justify-content-center.align-items-center.me-3.module-icon(
                        style=`width: 82px; height: 82px; background-color: ${curso.color || '#FF8C00'}; min-width: 82px;`
                      )
                        i.bi(class=(curso.icono || 'bi-journal-text'), style="font-size: 2.3rem; color: white;")
                      .text-start
                        h4.fw-bold.mb-2.text-dark(style="font-size: 1.4rem;")= curso.nombre
                        p.text-muted.m-0(style="font-size: 1.08rem; line-height: 1.5;")= curso.desc || 'Curso personalizado creado por ti'

        .row.mb-4.mt-4
          .col-12
            .card.border-0.shadow-sm.p-4(style="border-radius: 20px;")
              .d-flex.justify-content-between.align-items-center.flex-wrap.gap-3
                div
                  h3.fw-bold.mb-2(style="color:#2C3E50;") Crear un curso propio
                  p.text-muted.mb-0 Diseña tus propios ejercicios y guárdalos en la plataforma.
                if userid
                  a.btn.text-white.fw-bold(
                    href=`/cursos/nuevo?nombre=${encodeURIComponent(userNombre)}&userid=${encodeURIComponent(userid)}`,
                    style="background-color:#FF8C00; border-radius:14px; padding: 14px 20px;"
                  ) Crear curso
                else
                  span.text-muted Inicia sesión para crear cursos

        .mt-5.pb-5.management-section
          h3.fw-bold.mb-3(style="color: #2C3E50; font-size: 1.5rem;") Administrar mis cursos

          .management-grid
            .management-left
              .card.border-0.shadow-sm.mb-4(style="border-radius: 20px; border: 2px dashed #FF8C00; background-color: #FFF5E6;")
                .p-4.text-center
                  i.bi.bi-plus-circle-fill.mb-3(style="font-size: 2.8rem; color: #FF8C00;")
                  h4.fw-bold.text-dark(style="font-size: 1.35rem;") Añadir curso existente

                  form.mt-3(action="/principal/cursos", method="post")
                    input(type="hidden", name="userId", value=userid)
                    input(type="hidden", name="nombre", value=userNombre)
                    input#nombreCursoHidden(type="hidden", name="nombreCurso")
                    input#cursoIdHidden(type="hidden", name="cursoId")

                    select.form-select.mb-3(
                      name="cursoSelector",
                      required,
                      style="border-radius: 14px;",
                      onchange="const selected=this.options[this.selectedIndex]; document.getElementById('nombreCursoHidden').value=selected.dataset.nombre || ''; document.getElementById('cursoIdHidden').value=selected.dataset.cursoid || '';"
                    )
                      option(value="") Selecciona un curso para añadir...

                      if cursosDisponibles && cursosDisponibles.length
                        each curso in cursosDisponibles
                          option(
                            value=curso.tipo === 'dynamic' ? curso.cursoId : curso.nombreCurso,
                            data-nombre=curso.tipo === 'static' ? curso.nombreCurso : '',
                            data-cursoid=curso.tipo === 'dynamic' ? curso.cursoId : ''
                          )= curso.tipo === 'dynamic' ? `${curso.label} (creado por mí)` : curso.label
                      else
                        option(value="WhatsApp", data-nombre="WhatsApp", data-cursoid="") WhatsApp
                        option(value="YouTube", data-nombre="YouTube", data-cursoid="") YouTube
                        option(value="Cámara", data-nombre="Cámara", data-cursoid="") Cámara
                        option(value="Navegador", data-nombre="Navegador", data-cursoid="") Navegador
                        option(value="Ajustes", data-nombre="Ajustes", data-cursoid="") Ajustes
                        option(value="Llamadas", data-nombre="Llamadas", data-cursoid="") Llamadas

                    button.btn.text-white.fw-bold(type="submit", style="background-color: #FF8C00; border-radius: 14px; padding: 14px 20px;") + Añadir a mi lista

            .management-right
              h3.fw-bold.mb-3(style="color: #2C3E50; font-size: 1.5rem;") Mis Cursos Activos (Gestionar)

              if !userid
                .alert.alert-warning Debes iniciar sesión para gestionar tus cursos.
              else if cursosActivos.length === 0
                .alert.alert-light.shadow-sm Aún no tienes cursos añadidos manualmente. Añade uno para comenzar.
              else
                .row.g-2.m-0
                  each item in cursosActivos
                    .col-12.p-0.mb-3
                      .card.border-0.shadow-sm.p-4(style="border-radius: 18px;")
                        .d-flex.justify-content-between.align-items-center.flex-wrap.gap-3
                          .d-flex.align-items-center
                            .rounded.me-3.d-flex.justify-content-center.align-items-center(
                              style=`width: 52px; height: 52px; background-color: ${item.meta.color};`
                            )
                              i.bi(class=item.meta.icono, style="color: white; font-size: 1.4rem;")
                            .me-3
                              a.fw-bold.text-dark.d-block.text-decoration-none(style="font-size: 1.2rem;" href=item.href)= item.nombreCurso
                              span.text-muted(style="font-size: 1.05rem;") Progreso: #{item.progreso || 0}%
                          form(action=`/principal/cursos/${item.cursoId}/delete`, method="post")
                            input(type="hidden", name="userId", value=userid)
                            input(type="hidden", name="nombre", value=userNombre)
                            button.btn.btn-link.text-danger.p-0(type="submit", style="font-size: 1.4rem;")
                              i.bi.bi-trash-fill(style="font-size: 1.4rem;")

                        .mt-4.pt-3(style="border-top: 1px solid #f0f0f0;")
                          h4.fw-bold.mb-3(style="color:#D35400; font-size: 1.25rem;") Crear reseña de este curso
                          form(action=`/principal/cursos/${item.cursoId}/resenas`, method="post")
                            input(type="hidden", name="userId", value=userid)
                            input(type="hidden", name="nombre", value=userNombre)
                            .row.g-2
                              .col-md-3
                                select.form-select(name="rating", required)
                                  option(value="") Calificación
                                  option(value="1") 1 estrella
                                  option(value="2") 2 estrellas
                                  option(value="3") 3 estrellas
                                  option(value="4") 4 estrellas
                                  option(value="5") 5 estrellas
                              .col-md-7
                                input.form-control(type="text", name="comment", placeholder="Escribe tu comentario", required)
                              .col-md-2
                                button.btn.text-white.w-100(type="submit", style="background-color:#FF8C00; border-radius: 14px; padding: 14px 20px;") Guardar

                          - const courseReviews = reviewsByCourse[String(item.cursoId)] || []
                          if courseReviews.length
                            .mt-3
                              each review in courseReviews
                                .bg-light.rounded.p-3.mb-2
                                  .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
                                    strong(style="font-size: 1.05rem;")= review.userName
                                    span.badge.text-bg-warning.text-dark(style="font-size: 1rem;") #{review.rating}/5
                                  if review.comment
                                    p.text-muted.mb-0.mt-2(style="font-size: 1.05rem; line-height: 1.5;")= review.comment

block scripts
  script.
    async function eliminarCursoCreado(cursoId, nombreEncoded, useridEncoded) {
      const confirmado = confirm('¿Seguro que quieres eliminar este curso? Esta acción no se puede deshacer.');

      if (!confirmado) {
        return;
      }

      try {
        const response = await fetch(`/api/cursos/${cursoId}`, {
          method: 'DELETE'
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          alert(data.mensaje || 'No se pudo eliminar el curso.');
          return;
        }

        window.location.href = `/principal?nombre=${nombreEncoded}&userid=${useridEncoded}&success=${encodeURIComponent('Curso eliminado correctamente')}`;
      } catch (_err) {
        alert('Ocurrió un error al eliminar el curso.');
      }
    }