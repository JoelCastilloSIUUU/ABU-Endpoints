extends layout

block content
  .container-fluid.p-0
    .p-4.text-white(style="background:#25D366; border-bottom-left-radius:40px; border-bottom-right-radius:40px;")
      a.text-white.text-decoration-none(href=volverHref)
        i.bi.bi-arrow-left.me-2
        | Volver
      h2.h4.fw-bold.mt-3.mb-1= title
      p.small.m-0 Ejercicio completado dentro de #{modulo}

  .px-3.mt-4.pb-5
    .card.border-0.shadow-sm.p-4.mb-3(style="border-radius:20px; background:#fff7dc; border:1px solid #f2e2a5;")
      .text-center
        i.bi.bi-emoji-smile(style="font-size:2.2rem;")
        h3.h5.fw-bold.mt-2.mb-2 ¡Lo lograste!
        p.text-muted.mb-0 Has completado este ejercicio. Cada vez te sientes más cómodo con tu celular.

    a.btn.btn-warning.w-100.rounded-pill.py-3.fw-bold.text-white(href=continuarHref)
      | Continuar al siguiente ejercicio