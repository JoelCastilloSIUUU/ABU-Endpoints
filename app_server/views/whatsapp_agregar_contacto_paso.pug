extends layout

block content
  .container-fluid.p-0
    .p-4.text-white(style="background:#25D366; border-bottom-left-radius:40px; border-bottom-right-radius:40px;")
      a.text-white.text-decoration-none(href="/whatsapp/agregar-contacto", data-nav="tap")
        i.bi.bi-arrow-left.me-2
        | Volver
      h2.h4.fw-bold.mt-3.mb-1 Agregar un contacto
      p.small.m-0 Aprende a añadir un contacto en WhatsApp
      .d-flex.justify-content-between.align-items-center.mt-2
        .small Paso #{paso} de #{totalPasos}
        .small.fw-semibold #{progressText}
      .progress.mt-2(style="height:8px; border-radius:10px;")
        - const pct = Math.round((paso / totalPasos) * 100)
        .progress-bar(role="progressbar", style=`width:${pct}%`)

  .px-3.mt-4.pb-5
    .card.border-0.shadow-sm.p-3.mb-3(style="border-radius:20px;")
      .d-flex.align-items-start
        .rounded-circle.d-flex.justify-content-center.align-items-center.me-3(style="width:42px; height:42px; background:#e8f7ee; border:2px solid #25D366;")
          span.fw-bold(style="color:#25D366;")= paso
        .flex-grow-1
          h3.h6.fw-bold.mb-1.text-dark= titulo
          p.small.m-0
            span.text-muted= instruccion
            span.fw-bold(style="color:#C0392B;")= accion

    .card.border-0.shadow-sm.p-4.mb-3(style="border-radius:20px; background:#fff7dc; border:1px solid #f2e2a5;")
      .text-center
        i.bi.bi-grid-3x3-gap-fill(style="font-size:2rem; color:#4b4b4b;")
        p.fw-semibold.mt-2.mb-0= simulacion

    a.btn.btn-success.w-100.rounded-pill.py-3.fw-bold(href=nextHref, data-nav="tap")
      | Realizar acción